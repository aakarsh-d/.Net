@model College.Models.Student

<div class="card shadow p-4 text-center" style="max-width:400px;margin:auto;">
    <div class="bg-primary text-white p-3 rounded">
        <h5>College of Engineering</h5>
        <small>Affiliated to XYZ University</small>
    </div>

    <h6 class="mt-3">STUDENT ID CARD</h6>

    <img src="@Model.PhotoPath" class="img-thumbnail mt-3" width="120" />

    <h4 class="mt-3">@Model.FullName</h4>

    <p><strong>Roll No:</strong> @Model.RollNumber</p>
    <p><strong>Dept:</strong> @Model.Department</p>
    <p><strong>Course:</strong> @Model.Course</p>
    <p><strong>Year:</strong> @Model.Year</p>
    <p><strong>DOB:</strong> @Model.DOB.ToShortDateString()</p>
    <p><strong>Gender:</strong> @Model.Gender</p>
    <p><strong>Blood Group:</strong> @Model.BloodGroup</p>
    <p><strong>Mobile:</strong> @Model.Phone</p>

    <button onclick="window.print()" class="btn btn-primary mt-3">
        Download / Print ID Card
    </button>
</div>